# Ollama URL for the backend to connect
# The path '/ollama' will be redirected to the specified backend URL
OLLAMA_BASE_URL='http://localhost:11434'

OPENAI_API_BASE_URL=''
OPENAI_API_KEY=''

# ------------------------------------
# GPTHub + MWS GPT (OpenAI-compatible)
# ------------------------------------
# External endpoint (from MWS API docs):
# MWS_API_BASE_URL='https://api.gpt.mws.ru/v1'  # recommended for hackathon
# Internal corp endpoint (from extended MWS docs):
# MWS_API_BASE_URL='https://api.llmops.mts-corp.ru/v1'
MWS_API_BASE_URL='https://api.gpt.mws.ru/v1'
MWS_API_KEY=''

# Recommended model IDs from MWS docs
MWS_TEXT_MODEL='mts-anya'
MWS_VLM_MODEL='qwen2.5-vl-7b-instruct'
MWS_IMAGE_MODEL='qwen-image'
MWS_STT_MODEL='whisper-turbo-local'
MWS_EMBED_MODEL='bge-m3'

# Set to true for first start if old DB config overrides new env values.
RESET_CONFIG_ON_START='false'

# OpenWebUI routing to MWS
ENABLE_OPENAI_API='true'
OPENAI_API_BASE_URLS='https://api.gpt.mws.ru/v1'
OPENAI_API_KEYS=''
DEFAULT_MODELS='gpthub:auto'
# Force background task generation (title/tags/follow-ups) to use a text-capable model.
# This prevents task calls from accidentally using image-only models (e.g. qwen-image).
TASK_MODEL='mts-anya'
TASK_MODEL_EXTERNAL='mts-anya'

# Image generation via MWS
ENABLE_IMAGE_GENERATION='true'
IMAGE_GENERATION_ENGINE='openai'
IMAGE_GENERATION_MODEL='qwen-image'
# Keep disabled for MWS hackathon flow: avoids extra LLM prompt-refinement hop and reduces hangs.
ENABLE_IMAGE_PROMPT_GENERATION='false'
IMAGES_OPENAI_API_BASE_URL='https://api.gpt.mws.ru/v1'
IMAGES_OPENAI_API_KEY=''

# Audio transcription (ASR) via MWS
AUDIO_STT_ENGINE='openai'
AUDIO_STT_MODEL='whisper-turbo-local'
AUDIO_STT_OPENAI_API_BASE_URL='https://api.gpt.mws.ru/v1'
AUDIO_STT_OPENAI_API_KEY=''

# RAG embeddings via MWS
RAG_EMBEDDING_ENGINE='openai'
RAG_EMBEDDING_MODEL='bge-m3'
RAG_OPENAI_API_BASE_URL='https://api.gpt.mws.ru/v1'
RAG_OPENAI_API_KEY=''

# GPTHub: virtual models + capability router
GPTHUB_ENABLE_VIRTUAL_MODELS=true
GPTHUB_ROUTER_ENABLED=true
# Optional: force a specific router model id from /api/models
# GPTHUB_ROUTER_MODEL_ID='mws-gpt-alpha'
GPTHUB_ROUTER_MAX_CANDIDATES=16
GPTHUB_ROUTER_TEMPERATURE=0
GPTHUB_ROUTER_MAX_TOKENS=180

# GPTHub Memory 2.0 (LLM extractor)
# Optional: force a specific model for memory extraction.
# If empty, backend selects a suitable available text model automatically.
MEMORY_EXTRACTION_MODEL=''
# Minimum confidence for extracted facts to be persisted.
MEMORY_EXTRACTION_MIN_CONFIDENCE='0.72'
# Max number of facts extracted from one interaction.
MEMORY_EXTRACTION_MAX_FACTS='4'

# AUTOMATIC1111_BASE_URL="http://localhost:7860"

# For production, you should only need one host as
# fastapi serves the svelte-kit built frontend and backend from the same host and port.
# To test with CORS locally, you can set something like
# CORS_ALLOW_ORIGIN='http://localhost:5173;http://localhost:8080'
# WARNING: '*' allows ANY origin. Restrict in production to your actual domain(s).
# CORS_ALLOW_ORIGIN='*'
CORS_ALLOW_ORIGIN='http://localhost:5173;http://localhost:8080'

# WARNING: '*' trusts ANY proxy to set X-Forwarded-For. Set to '127.0.0.1' in production.
# FORWARDED_ALLOW_IPS='*'
FORWARDED_ALLOW_IPS='127.0.0.1'

# DO NOT TRACK
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false
